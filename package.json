{
  "name": "omp-designer",
  "version": "4.0.0",
  "type": "module",
  "description": "Autonomous AI design system with 12 skills, evidence tracking, deterministic validators, 161 palettes, and 57 font pairings.",
  "keywords": [
    "pi-package",
    "pi",
    "design",
    "ui",
    "ux",
    "design-system",
    "animation",
    "frontend",
    "color-palette",
    "typography",
    "anti-slop"
  ],
  "author": "Leandro",
  "license": "MIT",
  "repository": {
    "url": "git+https://github.com/LePro10/omp-designer.git"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "image": "https://pi.dev/logo-auto.svg"
  },
  "omp": {
    "extensions": [
      "./extension/index.ts"
    ]
  },
  "files": [
    "extension/",
    "extensions/",
    "skills/",
    "data/",
    "scripts/",
    "eval/",
    "docs/",
    "AGENTS.md",
    "package.json"
  ],
  "scripts": {
    "test:validators": "node scripts/__tests__/fix-ai-slop.test.mjs",
    "test:layout": "node scripts/__tests__/analyze-layout.test.mjs",
    "test:trace": "node scripts/__tests__/audit-trace.test.mjs",
    "test:eval": "node scripts/eval-suite.mjs validate",
    "check:release": "node scripts/check-release.mjs",
    "prepublishOnly": "npm run check:release && npm run test:validators && npm run test:layout && npm run test:trace && npm run test:eval"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3"
  }
}
